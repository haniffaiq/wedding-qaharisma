# Telegram RSVP delivery.
# WARNING: this is a frontend-only app. Vite inlines VITE_-prefixed vars into
# the built JS, so BOTH values below are publicly readable in the bundle.
# They are NOT secrets. Accepted trade-off (low-value target, no server).
VITE_TG_BOT_TOKEN=123456789:AA-your-bot-token-here
# One or more chat ids, comma-separated. RSVP is sent to every chat.
VITE_TG_CHAT_ID=123456789,987654321
