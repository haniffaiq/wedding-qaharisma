:8080 {
	root * /srv
	encode zstd gzip

	# SPA fallback: any unknown path → index.html so /guest-name routes work
	try_files {path} /index.html

	file_server
	header {
		Cache-Control "public, max-age=3600"
		# long-cache hashed assets only
	}

	@hashed path_regexp /assets/.*\.[a-f0-9]{8,}\..*
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	log {
		output stdout
		format console
	}
}
