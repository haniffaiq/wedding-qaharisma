# Wedding invite Telegram bot (VPS, behind nginx). Copy to .env on the server.
BOT_TOKEN=123456789:AA-your-bot-token-here
BASE_URL=https://risma-qahhar.kukuh.online
# Public HTTPS path nginx proxies to this bot:
WEBHOOK_URL=https://risma-qahhar.kukuh.online/api/telegram
# Local port the Node service listens on (nginx proxy_pass target):
PORT=8787
# Optional shared secret. If set, must match in server + set-webhook.
WEBHOOK_SECRET=change-me-to-a-random-string
